const express = require('express');
const bcrypt = require('bcryptjs');
const { v4: uuidv4 } = require('uuid');
const { verifyToken, requireRole } = require('../middleware/auth');

module.exports = function(db, notify, emailService) {
  const router = express.Router();
  router.use(verifyToken, requireRole('admin'));

  // Create company account
  router.post('/companies', (req, res) => {
    const { company_name, contact_person, email, phone, industry, country, website } = req.body;
    if (!company_name || !email) return res.status(400).json({ error: 'Company name and email required' });
    const existing = db.prepare('SELECT id FROM users WHERE email=?').get(email.toLowerCase().trim());
    if (existing) return res.status(409).json({ error: 'Email already registered' });

    const tempPassword = genPassword();
    const id = uuidv4();
    db.prepare(`INSERT INTO users (id,email,password,role,company_name,contact_person,phone,industry,country,website) VALUES (?,?,?,?,?,?,?,?,?,?)`)
      .run(id, email.toLowerCase().trim(), bcrypt.hashSync(tempPassword, 10), 'company', company_name, contact_person||'', phone||'', industry||'', country||'', website||'');

    db.prepare('INSERT INTO audit_log (action,actor,actor_role,target_id,details) VALUES (?,?,?,?,?)')
      .run('CREATE_COMPANY', req.user.id, 'admin', id, `Created: ${company_name}`);

    notify(id, 'welcome', 'Welcome to Insightbridge Awards', `Your account has been created. You can now submit award nominations for ${company_name}.`, '#/my-submissions');

    // Send welcome email
    const loginUrl = `${process.env.BASE_URL || 'https://insightbridge-awards.onrender.com'}/#/login`;
    if (emailService) emailService.welcomeCompany({ companyName: company_name, contactPerson: contact_person, email: email.toLowerCase().trim(), tempPassword, loginUrl });

    res.json({ id, email: email.toLowerCase().trim(), temporary_password: tempPassword, company_name });
  });

  router.get('/companies', (req, res) => {
    const companies = db.prepare(`
      SELECT u.*, COUNT(s.id) as submission_count, SUM(CASE WHEN s.status='approved' THEN 1 ELSE 0 END) as approved_count
      FROM users u LEFT JOIN submissions s ON u.id=s.user_id
      WHERE u.role='company' GROUP BY u.id ORDER BY u.created_at DESC
    `).all();
    res.json({ companies });
  });

  router.patch('/companies/:id/toggle', (req, res) => {
    const c = db.prepare('SELECT id,is_active,company_name FROM users WHERE id=? AND role=?').get(req.params.id, 'company');
    if (!c) return res.status(404).json({ error: 'Not found' });
    const ns = c.is_active ? 0 : 1;
    db.prepare('UPDATE users SET is_active=? WHERE id=?').run(ns, req.params.id);
    res.json({ success: true, is_active: ns });
  });

  // Create approver/agent accounts
  router.post('/users', (req, res) => {
    const { email, role, contact_person, company_name } = req.body;
    if (!email || !['approver', 'agent'].includes(role)) return res.status(400).json({ error: 'Invalid' });
    const existing = db.prepare('SELECT id FROM users WHERE email=?').get(email.toLowerCase().trim());
    if (existing) return res.status(409).json({ error: 'Email exists' });
    const tempPassword = genPassword();
    const id = uuidv4();
    db.prepare(`INSERT INTO users (id,email,password,role,company_name,contact_person) VALUES (?,?,?,?,?,?)`)
      .run(id, email.toLowerCase().trim(), bcrypt.hashSync(tempPassword, 10), role, company_name || (role === 'agent' ? 'Global Brands Magazine' : 'Insightbridge Research & Consulting'), contact_person || '');
    res.json({ id, email: email.toLowerCase().trim(), temporary_password: tempPassword, role });
  });

  router.get('/users', (req, res) => {
    const users = db.prepare('SELECT id,email,role,company_name,contact_person,created_at,last_login,is_active FROM users ORDER BY role,created_at DESC').all();
    res.json({ users });
  });

  router.get('/dashboard', (req, res) => {
    const stats = {
      companies: db.prepare("SELECT COUNT(*) as c FROM users WHERE role='company'").get().c,
      active_companies: db.prepare("SELECT COUNT(*) as c FROM users WHERE role='company' AND is_active=1").get().c,
      total_submissions: db.prepare('SELECT COUNT(*) as c FROM submissions').get().c,
      pending_review: db.prepare("SELECT COUNT(*) as c FROM submissions WHERE status='pending_review'").get().c,
      approved: db.prepare("SELECT COUNT(*) as c FROM submissions WHERE status='approved'").get().c,
      ai_approved: db.prepare("SELECT COUNT(*) as c FROM submissions WHERE status='ai_approved'").get().c,
      rejected: db.prepare("SELECT COUNT(*) as c FROM submissions WHERE status='rejected'").get().c,
      titles_awarded: db.prepare('SELECT COUNT(*) as c FROM award_titles').get().c,
    };
    const recent = db.prepare(`
      SELECT s.id,s.status,s.ai_verdict,s.ai_score,s.ai_probability,s.award_title,s.submitted_at,s.approved_at,
             u.company_name,u.industry,s.submitted_by_role
      FROM submissions s JOIN users u ON s.user_id=u.id ORDER BY s.created_at DESC LIMIT 15
    `).all();
    res.json({ stats, recent });
  });

  router.get('/submissions', (req, res) => {
    const subs = db.prepare(`
      SELECT s.*, u.company_name, u.email, u.industry, u.contact_person
      FROM submissions s JOIN users u ON s.user_id=u.id ORDER BY s.created_at DESC
    `).all();
    subs.forEach(s => { try { s.questionnaire = JSON.parse(s.questionnaire||'{}'); s.ai_evaluation = JSON.parse(s.ai_evaluation||'null'); s.title_conflicts = JSON.parse(s.title_conflicts||'null'); } catch {} });
    res.json({ submissions: subs });
  });

  router.get('/audit', (req, res) => {
    res.json({ logs: db.prepare('SELECT * FROM audit_log ORDER BY created_at DESC LIMIT 200').all() });
  });

  router.get('/titles', (req, res) => {
    res.json({ titles: db.prepare('SELECT * FROM award_titles ORDER BY year DESC, awarded_at DESC').all() });
  });

  // Reset any user's password (admin only)
  router.patch('/users/:id/reset-password', (req, res) => {
    const user = db.prepare('SELECT id,email,company_name FROM users WHERE id=?').get(req.params.id);
    if (!user) return res.status(404).json({ error: 'User not found' });
    const newPassword = genPassword();
    db.prepare('UPDATE users SET password=? WHERE id=?').run(bcrypt.hashSync(newPassword, 10), req.params.id);
    db.prepare('INSERT INTO audit_log (action,actor,actor_role,target_id,details) VALUES (?,?,?,?,?)')
      .run('RESET_PASSWORD', req.user.id, 'admin', req.params.id, `Reset password for: ${user.email}`);
    notify(req.params.id, 'info', 'Password Reset', 'Your password has been reset by an administrator. Please contact admin for your new credentials.', '');
    res.json({ success: true, email: user.email, new_password: newPassword });
  });

  // Edit any user's details (admin only)
  router.patch('/users/:id', (req, res) => {
    const user = db.prepare('SELECT id,email FROM users WHERE id=?').get(req.params.id);
    if (!user) return res.status(404).json({ error: 'User not found' });
    const { email, contact_person, company_name, phone, industry, country, website } = req.body;
    if (email && email.toLowerCase().trim() !== user.email) {
      const dup = db.prepare('SELECT id FROM users WHERE email=? AND id!=?').get(email.toLowerCase().trim(), req.params.id);
      if (dup) return res.status(409).json({ error: 'Email already in use' });
    }
    db.prepare(`UPDATE users SET email=COALESCE(?,email), contact_person=COALESCE(?,contact_person), company_name=COALESCE(?,company_name), phone=COALESCE(?,phone), industry=COALESCE(?,industry), country=COALESCE(?,country), website=COALESCE(?,website) WHERE id=?`)
      .run(email ? email.toLowerCase().trim() : null, contact_person||null, company_name||null, phone||null, industry||null, country||null, website||null, req.params.id);
    db.prepare('INSERT INTO audit_log (action,actor,actor_role,target_id,details) VALUES (?,?,?,?,?)')
      .run('EDIT_USER', req.user.id, 'admin', req.params.id, `Edited: ${user.email}`);
    res.json({ success: true });
  });

  // Delete user (admin only, can't delete self)
  router.delete('/users/:id', (req, res) => {
    if (req.params.id === req.user.id) return res.status(400).json({ error: 'Cannot delete yourself' });
    const user = db.prepare('SELECT id,email,role FROM users WHERE id=?').get(req.params.id);
    if (!user) return res.status(404).json({ error: 'User not found' });
    db.prepare('DELETE FROM notifications WHERE user_id=?').run(req.params.id);
    db.prepare('DELETE FROM users WHERE id=?').run(req.params.id);
    db.prepare('INSERT INTO audit_log (action,actor,actor_role,target_id,details) VALUES (?,?,?,?,?)')
      .run('DELETE_USER', req.user.id, 'admin', req.params.id, `Deleted: ${user.email} (${user.role})`);
    res.json({ success: true });
  });

  return router;
};

function genPassword() {
  const c = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
  let p = ''; for (let i = 0; i < 10; i++) p += c[Math.floor(Math.random()*c.length)];
  return p + '!@#$%'[Math.floor(Math.random()*5)];
}
