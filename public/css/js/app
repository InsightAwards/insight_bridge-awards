const App = (() => {
  let currentPage = null;
  let notifications = [];

  const pages = {
    '/': 'login',
    '/login': 'login',
    '/dashboard': 'dashboard',
    '/dashboard/companies': 'dashboard',
    '/dashboard/users': 'dashboard',
    '/dashboard/submissions': 'dashboard',
    '/dashboard/titles': 'dashboard',
    '/dashboard/audit': 'dashboard',
    '/dashboard/review': 'dashboard',
    '/dashboard/approved': 'dashboard',
    '/dashboard/rejected': 'dashboard',
    '/dashboard/my-submissions': 'dashboard',
    '/dashboard/my-companies': 'dashboard'
  };

  const init = async () => {
    const app = document.getElementById('app');
    if (!app) {
      const root = document.createElement('div');
      root.id = 'app';
      root.style.cssText = 'width:100%;height:100vh;';
      document.body.appendChild(root);
    }

    // Try to restore session
    if (API.isLoggedIn()) {
      try {
        const user = await API.getMe();
        API.setCurrentUser(user);
      } catch (err) {
        API.setToken(null);
        window.location.hash = '#/login';
      }
    }

    window.addEventListener('hashchange', handleRoute);
    handleRoute();
  };

  const handleRoute = async () => {
    const hash = window.location.hash.slice(1) || '/';
    const path = hash.split('?')[0];

    // Require login for dashboard
    if (path.startsWith('/dashboard') && !API.isLoggedIn()) {
      window.location.hash = '#/login';
      return;
    }

    // Redirect logged-in users away from login/home
    if ((path === '/' || path === '/login') && API.isLoggedIn()) {
      window.location.hash = '#/dashboard';
      return;
    }

    const pageType = pages[path];

    if (pageType === 'login') {
      renderLogin();
    } else if (pageType === 'dashboard') {
      renderDashboard(path);
    } else {
      renderNotFound();
    }
  };

  const render = (html) => {
    document.getElementById('app').innerHTML = html;
  };

  return {
    init,
    render,
    handleRoute
  };
})();

