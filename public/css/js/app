async function loadDashboardContent(page, path, role) {
  page.innerHTML = '<div style="text-align:center;padding:60px"><p style="color:#6b7280">Loading...</p></div>';
  try {
    if (role === 'admin') {
      if (path === '/dashboard') await renderAdminDashboard(page);
      else if (path === '/dashboard/companies') await renderAdminCompanies(page);
      else if (path === '/dashboard/users') await renderAdminUsers(page);
      else if (path === '/dashboard/submissions') await renderAdminSubmissions(page);
      else if (path === '/dashboard/titles') await renderTitles(page);
      else if (path === '/dashboard/audit') await renderAuditLog(page);
      else if (path.startsWith('/dashboard/submission/')) await renderSubmissionDetail(page, path.split('/').pop());
      else if (path.startsWith('/dashboard/review/')) await renderSubmissionDetail(page, path.split('/').pop());
      else await renderAdminDashboard(page);
    } else if (role === 'approver') {
      if (path === '/dashboard') await renderApproverQueue(page);
      else if (path === '/dashboard/approved') await renderApproverFiltered(page, 'approved');
      else if (path === '/dashboard/rejected') await renderApproverFiltered(page, 'rejected');
      else if (path === '/dashboard/titles') await renderTitles(page);
      else if (path.startsWith('/dashboard/review/')) await renderSubmissionDetail(page, path.split('/').pop());
      else await renderApproverQueue(page);
    } else if (role === 'agent') {
      if (path === '/dashboard') await renderAgentDashboard(page);
      else if (path === '/dashboard/submit') await renderAgentSubmit(page);
      else if (path === '/dashboard/my-submissions') await renderMySubmissions(page);
      else if (path === '/dashboard/my-companies') await renderAgentCompaniesPage(page);
      else if (path === '/dashboard/create-company') await renderCreateCompany(page);
      else if (path.startsWith('/dashboard/submission/')) await renderSubmissionDetail(page, path.split('/').pop());
      else await renderAgentDashboard(page);
    } else {
      if (path === '/dashboard' && window.location.hash.includes('new=true')) await renderNewSubmission(page);
      else if (path === '/dashboard') await renderCompanyDashboard(page);
      else if (path === '/dashboard/my-submissions') await renderMySubmissions(page);
      else if (path.startsWith('/dashboard/submission/')) await renderSubmissionDetail(page, path.split('/').pop());
      else await renderCompanyDashboard(page);
    }
  } catch (err) {
    page.innerHTML = `<div class="alert alert-danger">Error loading page: ${Utils.esc(err.message)}</div>`;
  }
}

