        <select class="form-select" id="sub-category"><option>Industry Excellence</option><option>Best Banking Brand</option><option>Best Insurance Brand</option><option>Best Technology Brand</option><option>Best Real Estate Brand</option><option>Best Hospitality Brand</option><option>Best Healthcare Brand</option><option>Most Innovative Company</option><option>Best Employer Brand</option><option>Best Digital Transformation</option><option>Best CSR Initiative</option><option>Fastest Growing Brand</option></select>
      </div>
    </div></div>
    ${Object.entries(sections).map(([key, sec]) => `
      <div class="card mb-16"><div class="card-header"><h2>${sectionIcons[key]||'📋'} ${sec.label}</h2></div><div class="card-body">
        ${sec.questions.map(q => renderQ(q)).join('')}
      </div></div>
    `).join('')}
    <div class="flex-between mt-24" style="padding-top:24px;border-top:1px solid var(--gray-200)">
      <div></div><div class="flex gap-12"><button class="btn btn-outline" id="comp-save">Save Draft</button><button class="btn btn-gold btn-lg" id="comp-submit">🚀 Submit for AI Evaluation</button></div>
    </div><div id="comp-result" class="mt-16"></div>`;

  // Title check
  let tt;
  document.getElementById('sub-title').addEventListener('input', (e) => {
    clearTimeout(tt);
    tt = setTimeout(async () => {
      if (e.target.value.length < 5) return;
      try {
        const check = await API.checkTitle(e.target.value);
        const el = document.getElementById('title-check');
        if (check.hasExact) el.innerHTML = `<div class="alert alert-danger">⛔ This exact title already exists!</div>`;
        else if (check.hasSimilar) el.innerHTML = `<div class="alert alert-warning">⚠️ Similar titles found. This may require manual approval.</div>`;
        else el.innerHTML = `<div class="alert alert-success">✅ Title is unique.</div>`;
      } catch {}
    }, 500);
  });

  bindFormInteractions(formData);

  document.getElementById('comp-save').onclick = async () => {
    collectFormData(formData, sections);
    try {
      await API.saveDraft({ questionnaire: formData, award_title: document.getElementById('sub-title').value, award_category: document.getElementById('sub-category').value });
      Utils.toast('Draft saved', 'success');
    } catch (err) { Utils.toast(err.message, 'error'); }
  };

  document.getElementById('comp-submit').onclick = async () => {
    const btn = document.getElementById('comp-submit');
    btn.disabled = true; btn.textContent = '🤖 AI evaluating...';
    collectFormData(formData, sections);
    try {
      const draft = await API.saveDraft({ questionnaire: formData, award_title: document.getElementById('sub-title').value, award_category: document.getElementById('sub-category').value });
      const result = await API.submitForEval(draft.id);
      Utils.toast(`Score: ${result.evaluation.totalScore}/100 — ${result.status}`, result.evaluation.totalScore >= 65 ? 'success' : 'warning');
      location.hash = `#/dashboard/submission/${draft.id}`;
    } catch (err) {
      if (err.message && err.message.includes('Missing')) {
        try {
          const validation = await API.validateSubmission(draft?.id || '');
          if (validation && validation.missing && validation.missing.length) {
            const resultDiv = document.getElementById('comp-result');
            resultDiv.innerHTML = `<div class="alert alert-warning"><strong>Please complete the following:</strong><ul style="margin:8px 0 0;padding-left:20px">${validation.missing.map(m => `<li>${Utils.esc(m)}</li>`).join('')}</ul></div>`;
          }
        } catch {}
      }
      Utils.toast(err.message || 'Submission failed', 'error');
      btn.disabled = false; btn.textContent = '🚀 Submit for AI Evaluation';
    }
  };
}

