// ============================================================================
// 1. API MODULE - Token Management & API Calls
// ============================================================================

const API = (() => {
  const BASE_URL = '/api';
  let token = localStorage.getItem('token');
  let currentUser = null;

  const setToken = (newToken) => {
    token = newToken;
    if (newToken) {
      localStorage.setItem('token', newToken);
    } else {
      localStorage.removeItem('token');
    }
  };

  const getToken = () => token;

  const getAuthHeader = () => ({
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  });

  const request = async (endpoint, options = {}) => {
    const url = `${BASE_URL}${endpoint}`;
    const headers = options.headers || getAuthHeader();

    try {
      const response = await fetch(url, {
        ...options,
        headers
      });

      if (!response.ok) {
        if (response.status === 401) {
          setToken(null);
          currentUser = null;
          window.location.hash = '#/login';
          throw new Error('Unauthorized');
        }
        const error = await response.json();
        throw new Error(error.message || `API Error: ${response.status}`);
      }

      return await response.json();
    } catch (err) {
      console.error('API Error:', err);
      throw err;
    }
  };

  const isLoggedIn = () => !!token;

  return {
    setToken,
    getToken,
    isLoggedIn,
    getCurrentUser: () => currentUser,
    setCurrentUser: (user) => { currentUser = user; },

    // ========== AUTH ENDPOINTS ==========
    login: (email, password) =>
      request('/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      }),

    getMe: () =>
      request('/auth/me'),

    // ========== ADMIN ENDPOINTS ==========
    getDashboard: () =>
      request('/admin/dashboard'),

    getCompanies: (filters = {}) =>
      request(`/admin/companies?${new URLSearchParams(filters)}`),

    createCompany: (data) =>
      request('/admin/companies', {
        method: 'POST',
        body: JSON.stringify(data)
      }),

    toggleCompany: (id, active) =>
      request(`/admin/companies/${id}/toggle`, {
        method: 'PATCH',
        body: JSON.stringify({ active })
      }),

    createUser: (data) =>
      request('/admin/users', {
        method: 'POST',
        body: JSON.stringify(data)
      }),

    getUsers: (filters = {}) =>
      request(`/admin/users?${new URLSearchParams(filters)}`),

    getAdminSubmissions: (filters = {}) =>
      request(`/admin/submissions?${new URLSearchParams(filters)}`),

    getAuditLog: (filters = {}) =>
      request(`/admin/audit?${new URLSearchParams(filters)}`),

    getTitles: () =>
      request('/admin/titles'),

    resetUserPassword: (userId) =>
      request(`/admin/users/${userId}/reset-password`, { method: 'PATCH' }),

    editUser: (userId, data) =>
      request(`/admin/users/${userId}`, { method: 'PATCH', body: JSON.stringify(data) }),

    deleteUser: (userId) =>
      request(`/admin/users/${userId}`, { method: 'DELETE' }),

    changeMyPassword: (current_password, new_password) =>
      request('/auth/password', { method: 'PUT', body: JSON.stringify({ current_password, new_password }) }),

    // ========== APPROVER ENDPOINTS ==========
    getApproverDashboard: () =>
      request('/approver/dashboard'),

    approveSubmission: (submissionId, feedback = '') =>
      request(`/approver/submissions/${submissionId}/approve`, {
        method: 'POST',
        body: JSON.stringify({ feedback })
      }),

    rejectSubmission: (submissionId, reason) =>
      request(`/approver/submissions/${submissionId}/reject`, {
        method: 'POST',
        body: JSON.stringify({ reason })
      }),

    requestRevision: (submissionId, comments) =>
      request(`/approver/submissions/${submissionId}/revision`, {
        method: 'POST',
        body: JSON.stringify({ comments })
      }),

    // ========== AGENT & COMPANY ENDPOINTS ==========
    getQuestionnaire: () =>
      request('/submissions/questionnaire'),

    checkTitle: (title) =>
      request('/submissions/check-title', {
        method: 'POST',
        body: JSON.stringify({ title })
      }),

    saveDraft: (data) =>
      request('/submissions/draft', {
        method: 'POST',
        body: JSON.stringify(data)
      }),

    submitForEval: (submissionId) =>
      request(`/submissions/${submissionId}/submit`, {
        method: 'POST'
      }),

    getMySubmissions: () =>
      request('/submissions/my'),

    getSubmission: (submissionId) =>
      request(`/submissions/${submissionId}`),

    getCompaniesList: () =>
      request('/companies'),

    // ========== NOTIFICATIONS ==========
    getNotifications: () =>
      request('/notifications'),

    markRead: (notificationId) =>
      request(`/notifications/${notificationId}/read`, {
        method: 'PATCH'
      }),

    markAllRead: () =>
      request('/notifications/read-all', {
        method: 'PATCH'
      }),

    // ========== AGENT ENDPOINTS ==========
    getAgentDashboard: () =>
      request('/agent/dashboard'),

    agentCreateCompany: (data) =>
      request('/agent/companies', {
        method: 'POST',
        body: JSON.stringify(data)
      }),

    getAgentCompanies: () =>
      request('/agent/companies'),

    // ========== VALIDATION ==========
    validateSubmission: (submissionId) =>
      request(`/submissions/${submissionId}/validate`, {
        method: 'POST'
      }),

    // ========== COMPANY DASHBOARD ==========
    getCompanyDashboard: () =>
      request('/submissions/mine')
  };
})();

