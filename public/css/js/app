  questions.forEach(q => {
    if (!sections[q.criterion]) sections[q.criterion] = { label: q.criterionLabel, questions: [] };
    sections[q.criterion].questions.push(q);
  });

  page.innerHTML = `
    <div style="background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%);color:#fff;padding:32px;border-radius:12px;margin-bottom:24px">
      <h1 style="font-size:22px;font-weight:800;margin-bottom:4px">Submit Award Nomination</h1>
