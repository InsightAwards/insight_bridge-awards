window.handleApprove = (id, title) => {
  const notes = prompt('Approval notes (optional):');
  const override = prompt('Override title? (leave blank to keep):', title);
  API.approveSubmission(id, { notes, override_title: override || undefined }).then(() => {
    Utils.toast('Submission approved!', 'success');
    location.reload();
  }).catch(err => Utils.toast(err.message, 'error'));
};

window.handleReject = (id) => {
  const reason = prompt('Rejection reason:');
  if (!reason) return;
  API.rejectSubmission(id, { reason }).then(() => {
    Utils.toast('Submission rejected', 'warning');
    location.reload();
  }).catch(err => Utils.toast(err.message, 'error'));
};

window.handleRevision = (id) => {
  const notes = prompt('What needs to be revised?');
  if (!notes) return;
  API.requestRevision(id, { notes }).then(() => {
    Utils.toast('Revision requested', 'info');
    location.reload();
  }).catch(err => Utils.toast(err.message, 'error'));
};

