      <div class="form-group"><label>Award Title <span class="form-required">*</span></label>
        <input class="form-input" id="agent-title" placeholder="e.g. Best Banking Brand UAE 2026" style="font-size:15px">
        <div id="title-check" class="mt-8"></div>
      </div>
      <div class="form-group"><label>Award Category</label>
        <select class="form-select" id="agent-category"><option>Industry Excellence</option><option>Best Banking Brand</option><option>Best Insurance Brand</option><option>Best Technology Brand</option><option>Best Real Estate Brand</option><option>Best Hospitality Brand</option><option>Best Healthcare Brand</option><option>Most Innovative Company</option><option>Best Employer Brand</option><option>Best Digital Transformation</option><option>Best CSR Initiative</option><option>Fastest Growing Brand</option></select>
      </div>
    </div></div>
    ${Object.entries(sections).map(([key, sec]) => `
      <div class="card mb-16"><div class="card-header"><h2>${sectionIcons[key]||'📋'} ${sec.label}</h2></div><div class="card-body">
        ${sec.questions.map(q => renderQ(q)).join('')}
      </div></div>
    `).join('')}
    <div class="flex-between mt-24" style="padding-top:24px;border-top:1px solid var(--gray-200)">
      <div></div><div class="flex gap-12"><button class="btn btn-outline" id="agent-save">Save Draft</button><button class="btn btn-gold btn-lg" id="agent-submit">🚀 Submit for AI Evaluation</button></div>
    </div>
    <div id="agent-result" class="mt-16"></div>`;

  // Title check
  let titleTimer;
  document.getElementById('agent-title').addEventListener('input', (e) => {
    clearTimeout(titleTimer);
    titleTimer = setTimeout(async () => {
      if (e.target.value.length < 5) return;
      try {
        const check = await API.checkTitle(e.target.value);
        const el = document.getElementById('title-check');
        if (check.hasExact) el.innerHTML = `<div class="alert alert-danger">⛔ This exact title already exists! Choose a different title.</div>`;
        else if (check.hasSimilar) el.innerHTML = `<div class="alert alert-warning">⚠️ Similar titles found: ${check.conflicts.map(c=>`"${Utils.esc(c.title)}" (${(c.similarity*100).toFixed(0)}% match)`).join(', ')}. This will require manual approval.</div>`;
        else el.innerHTML = `<div class="alert alert-success">✅ Title is unique.</div>`;
      } catch {}
    }, 500);
  });

  // Bind scale/pill interactions
  bindFormInteractions(formData);

  document.getElementById('agent-save').onclick = async () => {
    collectFormData(formData, sections);
    try {
      await API.saveDraft({ company_id: document.getElementById('agent-company').value, questionnaire: formData, award_title: document.getElementById('agent-title').value, award_category: document.getElementById('agent-category').value });
      Utils.toast('Draft saved', 'success');
    } catch (err) { Utils.toast(err.message, 'error'); }
  };

  document.getElementById('agent-submit').onclick = async () => {
    const compId = document.getElementById('agent-company').value;
    if (!compId) { Utils.toast('Select a company first', 'warning'); return; }
    const btn = document.getElementById('agent-submit');
    btn.disabled = true; btn.textContent = '🤖 AI evaluating...';
    collectFormData(formData, sections);
    try {
      const draft = await API.saveDraft({ company_id: compId, questionnaire: formData, award_title: document.getElementById('agent-title').value, award_category: document.getElementById('agent-category').value });
      const result = await API.submitForEval(draft.id);
      Utils.toast(`Evaluation complete! Score: ${result.evaluation.totalScore}/100`, result.evaluation.totalScore >= 65 ? 'success' : 'warning');
      location.hash = `#/dashboard/submission/${draft.id}`;
    } catch (err) {
      // Handle missing data validation
      if (err.message && err.message.includes('Missing')) {
        try {
          const validation = await API.validateSubmission(draft?.id || '');
          if (validation && validation.missing && validation.missing.length) {
            const resultDiv = document.getElementById('agent-result');
            resultDiv.innerHTML = `<div class="alert alert-warning"><strong>Missing Information:</strong><ul style="margin:8px 0 0;padding-left:20px">${validation.missing.map(m => `<li>${Utils.esc(m)}</li>`).join('')}</ul><p class="mt-8 text-sm">Please complete the missing fields and try again. An email has been sent to the company.</p></div>`;
          }
        } catch {}
      }
      Utils.toast(err.message || 'Submission failed', 'error');
      btn.disabled = false; btn.textContent = '🚀 Submit for AI Evaluation';
    }
  };
}

